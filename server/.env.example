# Backend environment variables
# Copy to .env for local development or configure these in Render/Vercel.

# Required. MongoDB connection string with a database name included.
# Example:
# mongodb+srv://username:password@cluster.mongodb.net/expproappdb?retryWrites=true&w=majority&appName=expproappdb
DATABASE_URL=

# Required. Use a long random secret in production.
JWT_SECRET=

# Optional. Comma-separated frontend origins allowed by CORS.
# Example:
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=https://expiry-and-tasks-management-system.vercel.app,http://localhost:3000,http://localhost:5173

# Optional runtime settings.
NODE_ENV=production
PORT=5000
