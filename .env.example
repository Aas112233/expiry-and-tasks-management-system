# Frontend environment variables
# Copy to .env.local for local development or configure these in Vercel.

# Backend API base URL. Required in production.
VITE_API_BASE_URL=https://your-backend-domain.vercel.app/api

# API timeout used by the frontend service layer.
VITE_API_TIMEOUT=30000

# Sentry configuration. Optional.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# Frontend release/version label shown in monitoring.
VITE_APP_VERSION=1.2.0

# Optional legacy key expected by vite.config.ts.
# Leave empty unless you actually use it in the app.
GEMINI_API_KEY=
